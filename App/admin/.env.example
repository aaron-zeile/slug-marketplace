# PostgreSQL (admin app + docker-compose db service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
ADMIN_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/admindb

# Dev sign-in after `npm run dev` (see App/admin/db/data.sql)
# UCSC admins (password: slugmarket123):
#   admin1@slugmarketplace.ucsc.edu
#   admin2@slugmarketplace.ucsc.edu
#   admin3@slugmarketplace.ucsc.edu
# Local admin: admin@slugmarketplace.local / admin123

# Iron-session secret (min 32 chars)
SESSION_SECRET=replace_with_a_random_32_char_secret_here

# Items microservice base URL (used by admin to manage listings/reviews)
ITEMS_SERVICE_URL=http://localhost:4500/graphql

# Must match ADMIN_INTERNAL_SECRET in ItemsService
ADMIN_INTERNAL_SECRET=dev-internal-secret

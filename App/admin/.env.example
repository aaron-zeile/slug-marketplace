# PostgreSQL connection URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://sluguser:slugpassword@localhost:5432/slugmarketplace

# Docker Compose overrides (optional — defaults used in docker-compose.yml)
POSTGRES_USER=sluguser
POSTGRES_PASSWORD=slugpassword
POSTGRES_DB=slugmarketplace

# Iron-session secret (min 32 chars)
SESSION_SECRET=replace_with_a_random_32_char_secret_here

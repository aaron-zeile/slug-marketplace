{
  "name": "seller",
  "version": "1.0.0",
  "type": "module",
  "description": "Slug marketplace seller app",
  "author": "CSE187 Group 4",
  "license": "UNLICENSED",
  "repository": "none",
  "scripts": {
    "dev": "concurrently -k -n client,server -c blue,green \"cd client && vite\" \"tsx watch server/index.ts\"",
    "build": "npm run clean && vite build --config client/vite.config.ts && tsc -p tsconfig.server.build.json",
    "start": "cross-env NODE_ENV=production node dist/server/index.js",
    "server": "tsx watch --clear-screen=false server/index.ts",
    "client": "vite",
    "preview": "vite preview",
    "clean": "rimraf dist .turbo",
    "test": "run-s test:client test:server",
    "test:client": "vitest run --config client/vitest.client.config.ts --no-file-parallelism --coverage",
    "test:server": "vitest run --config server/vitest.server.config.ts --no-file-parallelism --coverage",
    "typecheck": "run-s typecheck:client typecheck:server",
    "typecheck:client": "tsc --noEmit -p tsconfig.client.json",
    "typecheck:server": "tsc --noEmit -p tsconfig.server.json",
    "lint": "run-s lint:client lint:server",
    "lint:client": "eslint client/src --fix",
    "lint:server": "eslint server --fix"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^7.3.4",
    "@mui/material": "^7.3.4",
    "cross-env": "^10.1.0",
    "express": "^5.1.0",
    "msw": "^2.13.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.73.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/express": "^5.0.3",
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-typescript": "^3.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.4.0",
    "jsdom": "^26.1.0",
    "npm-package-json-lint": "^9.0.0",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vite": "^7.1.12",
    "vitest": "^3.2.4"
  }
}

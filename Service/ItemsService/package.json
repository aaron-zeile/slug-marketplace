{
  "name": "itemsService",
  "version": "1.1.0",
  "description": "Service for Items",
  "license": "UNLICENSED",
  "repository": "none",
  "devDependencies": {
    "@eslint/js": "*",
    "@types/cors": "^2.8.19",
    "@types/express": "*",
    "@types/node": "*",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "*",
    "eslint-config-typescript": "*",
    "globals": "8",
    "nodemon": "*",
    "supertest": "^7.2.2",
    "ts-node": "*",
    "typescript": "*",
    "typescript-eslint": "*",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "class-validator": "*",
    "cors": "^2.8.6",
    "dotenv": "*",
    "express": "*",
    "graphql": "*",
    "graphql-http": "*",
    "graphql-playground-middleware-express": "*",
    "pg": "^8.20.0",
    "reflect-metadata": "*",
    "type-graphql": "*"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts",
    "exec": "ts-node src/server.ts"
  },
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "node build/server.js",
    "lint": "eslint src/**/*.[jt]s --fix",
    "cpd": "jscpd src test --silent",
    "test": "vitest run --no-file-parallelism --testTimeout=3000 --coverage"
  }
}

{
  "name": "cse187-containerised-microservice-example-auth-service",
  "version": "1.1.0",
  "description": "CSE187 Containerised MicroService Example Auth Service",
  "author": "David Harrison <dcharris@ucsc.edu>",
  "license": "UNLICENSED",
  "repository": "none",
  "devDependencies": {
    "@eslint/js": "*",
    "@types/cors": "*",
    "@types/express": "*",
    "@types/jsonwebtoken": "*",
    "@types/node": "*",
    "@types/pg": "*",
    "@types/swagger-ui-express": "*",
    "concurrently": "*",
    "eslint": "*",
    "eslint-config-typescript": "*",
    "globals": "8",
    "joi": "*",
    "nodemon": "*",
    "supertest": "*",
    "ts-node": "*",
    "typescript": "*",
    "typescript-eslint": "*"
  },
  "dependencies": {
    "cors": "*",
    "dotenv": "*",
    "express": "*",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "*",
    "pg": "*",
    "swagger-ui-express": "*",
    "tsoa": "*"
  },
  "nodemonConfig": {
    "watch": [
      "."
    ],
    "ext": "ts",
    "exec": "ts-node server.ts"
  },
  "scripts": {
    "start": "node build/server.js",
    "prebuild": "npm run swagger",
    "build": "tsc",
    "predev": "npm run swagger",
    "dev": "concurrently \"nodemon\" \"nodemon -x tsoa spec-and-routes\"",
    "swagger": "tsoa spec-and-routes",
    "lint": "eslint *.ts --fix"
  }
}

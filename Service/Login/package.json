{
  "name": "cse187-containerised-microservice-example-auth-service",
  "version": "1.1.0",
  "description": "CSE187 Containerised MicroService Example Auth Service",
  "author": "David Harrison <dcharris@ucsc.edu>",
  "license": "UNLICENSED",
  "repository": "none",
  "devDependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@eslint/js": "10.0.1",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.6.1",
    "@types/pg": "8.20.0",
    "@types/swagger-ui-express": "4.1.8",
    "@vitest/coverage-v8": "^4.1.5",
    "concurrently": "9.2.1",
    "eslint": "10.3.0",
    "eslint-config-typescript": "3.0.0",
    "globals": "8.18.0",
    "joi": "18.2.1",
    "nodemon": "3.1.14",
    "supertest": "7.2.2",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2"
  },
  "dependencies": {
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "google-auth-library": "10.6.2",
    "jsonwebtoken": "9.0.3",
    "pg": "8.20.0",
    "swagger-ui-express": "5.0.1",
    "tsoa": "7.0.0-alpha.0"
  },
  "nodemonConfig": {
    "watch": [
      "."
    ],
    "ext": "ts",
    "exec": "ts-node server.ts"
  },
  "scripts": {
    "start": "node build/server.js",
    "prebuild": "npm run swagger",
    "build": "tsc",
    "test": "vitest run --config vitest.config.ts --no-file-parallelism --coverage",
    "predev": "npm run swagger",
    "dev": "concurrently \"nodemon\" \"nodemon -x tsoa spec-and-routes\"",
    "dev:serve": "nodemon --watch server.ts --watch app.ts --watch service.ts --watch src --ignore src/generated --ignore generated --ignore swagger.json --exec ts-node server.ts",
    "swagger": "tsoa spec-and-routes",
    "lint": "eslint *.ts --fix"
  }
}

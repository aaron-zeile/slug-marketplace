# Postgres (order-service-db via docker compose)
POSTGRES_HOST=localhost
POSTGRES_PORT=5435
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
ORDER_POSTGRES_DB=orders

# Mailgun (https://documentation.mailgun.com/docs/mailgun/api/send)
# Purchase/shipping/delivery emails are skipped when these are unset.
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.your-domain.com
MAILGUN_FROM=Marketplace <postmaster@sandboxXXXX.mailgun.org>

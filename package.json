{
  "scripts": {
    "containerised": "npm run build && npm run compose",
    "compose": "docker compose up --build",
    "installs": "npm install && npm run install-admin && npm run install-seller && npm run install-shopper && npm run install-items && npm run install-login",
    "install-admin": "cd App/admin && npm install",
    "install-seller": "cd App/seller && npm install",
    "install-shopper": "cd App/shopper && npm install",
    "install-items": "cd Service/ItemsService && npm install",
    "install-login": "cd Service/Login && npm install",
    "cis": "npm ci && npm run ci-admin && npm run ci-seller && npm run ci-shopper && npm run ci-items && npm run ci-login",
    "ci-admin": "cd App/admin && npm ci",
    "ci-seller": "cd App/seller && npm ci",
    "ci-shopper": "cd App/shopper && npm ci",
    "ci-items": "cd Service/ItemsService && npm ci",
    "ci-login": "cd Service/Login && npm ci",
    "build": "npm run build-admin && npm run build-seller && npm run build-shopper && npm run build-items && npm run build-login",
    "build-admin": "cd App/admin && npm run build",
    "build-seller": "cd App/seller && npm run build",
    "build-shopper": "cd App/shopper && npm run build",
    "build-items": "cd Service/ItemsService && npm run build",
    "build-login": "cd Service/Login && npm run build",
    "start": "concurrently --kill-others \"npm run start-admin\" \"npm run start-seller\" \"npm run start-shopper\" \"npm run start-items\" \"npm run start-login\"",
    "start-admin": "cd App/admin && npm start",
    "start-seller": "cd App/seller && npm start",
    "start-shopper": "cd App/shopper && npm start",
    "start-items": "cd Service/ItemsService && npm start",
    "start-login": "cd Service/Login && npm start",
    "docker:reset": "powershell -ExecutionPolicy Bypass -File ./scripts/docker-reset.ps1 -Detached",
    "lint": "npm run lint-admin && npm run lint-seller && npm run lint-shopper",
    "lint-admin": "cd App/admin && npm run lint",
    "lint-seller": "cd App/seller && npm run lint",
    "lint-shopper": "cd App/shopper && npm run lint",
    "test": "npm run test-admin && npm run test-seller && npm run test-shopper",
    "test-admin": "cd App/admin && npm test",
    "test-seller": "cd App/seller && npm test",
    "test-shopper": "cd App/shopper && npm test",
    "e2e": "vitest run e2e --pool=threads --no-file-parallelism --testTimeout=20000"
  },
  "dependencies": {
    "concurrently": "9.2.1",
    "google-auth-library": "^10.6.2"
  },
  "devDependencies": {
    "dotenv": "^17.2.3",
    "pg": "^8.20.0",
    "puppeteer": "^24.32.0",
    "vitest": "4.1.5"
  }
}
